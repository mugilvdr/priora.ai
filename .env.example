# ── Database ─────────────────────────────────────────────────────────────────
# Neon (current): both DATABASE_URL and DIRECT_URL use the same connection string
# Supabase: DATABASE_URL = pooler URL (port 6543), DIRECT_URL = direct URL (port 5432)
DATABASE_URL="postgresql://user:password@host:5432/db"
DIRECT_URL="postgresql://user:password@host:5432/db"

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Only the publishable key and secret key are required.
# Sign-in/sign-up URLs and post-auth redirects are handled in code (middleware + page redirects).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."

# ── AI Models (all optional — Groq is free and required for extraction) ────────
GROQ_API_KEY="gsk_..."              # Required — used for invention param extraction + default model
GOOGLE_API_KEY="AIza..."            # Optional — enables Gemini 2.5 Flash / Pro
ANTHROPIC_API_KEY="sk-ant-..."      # Optional — enables Claude 3.5 / 3.7 Sonnet
OPENAI_API_KEY="sk-..."             # Optional — enables GPT-4o / GPT-4o Mini

# ── EPO Open Patent Services (OPS) API ────────────────────────────────────────
# Enables structured full-text search across 100M+ patents via EPO's official API.
# Covers EP, WO (PCT), US, CN, JP, KR and other jurisdictions through a single API.
# Get credentials at https://developers.epo.org (free tier: 200 req/week)
EPO_OPS_CONSUMER_KEY="..."          # OAuth2 Consumer Key from EPO developer portal
EPO_OPS_CONSUMER_SECRET="..."       # OAuth2 Consumer Secret from EPO developer portal

# ── Supabase setup notes ──────────────────────────────────────────────────────
# 1. Create a new Supabase project at supabase.com
# 2. Go to Project Settings > Database > Connection String
# 3. Set DATABASE_URL to the "Transaction" pooler URL (port 6543, add ?pgbouncer=true)
# 4. Set DIRECT_URL to the "Session" pooler URL (port 5432) or the direct connection
# 5. Run `npm run db:migrate` to apply migrations
#
# Example Supabase URLs:
# DATABASE_URL="postgres://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgres://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Existing Neon DB migration one-time setup ─────────────────────────────────
# If you already have a Neon DB from a previous `prisma db push` deployment:
# 1. Set DATABASE_URL and DIRECT_URL in your environment
# 2. Run `npm run db:baseline` once to mark the initial migration as applied
# 3. Run `npm run db:migrate` to apply only the new migrations (new columns)
# 4. Deploy normally — `npm run build` will run `prisma migrate deploy` automatically
